<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:Companion.ViewModels"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="80"
             x:Class="Companion.Views.HeaderView"
             x:DataType="vm:MainViewModel"
             Height="80">

    <!-- Put styles in the Styles section, not in Resources -->
    <UserControl.Styles>
    <!-- Base button style -->
    <Style Selector="Button.CircularButton">
        <Setter Property="Template">
            <ControlTemplate>
                <Grid>
                    <Ellipse x:Name="ButtonBackground" Fill="{DynamicResource CircularButtonFill}" />
                    <Ellipse x:Name="GlowEffect" Fill="Transparent" Margin="0" Opacity="0" />
                    <ContentPresenter Content="{TemplateBinding Content}"
                                     ContentTemplate="{TemplateBinding ContentTemplate}"
                                     HorizontalAlignment="Center"
                                     VerticalAlignment="Center" />
                </Grid>
            </ControlTemplate>
        </Setter>
    </Style>

    <!-- Hover style -->
    <Style Selector="Button.CircularButton:pointerover /template/ Ellipse#ButtonBackground">
        <Setter Property="Fill" Value="{DynamicResource CircularButtonHoverFill}" />
    </Style>

    <!-- Red pulse animation -->
    <Style Selector="Button.CircularButton.RedPulse /template/ Ellipse#GlowEffect">
        <Style.Animations>
            <Animation Duration="0:0:1" IterationCount="INFINITE">
                <KeyFrame Cue="0%">
                    <Setter Property="Fill" Value="Red" />
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
                <KeyFrame Cue="50%">
                    <Setter Property="Fill" Value="Red" />
                    <Setter Property="Opacity" Value="0.7" />
                </KeyFrame>
                <KeyFrame Cue="100%">
                    <Setter Property="Fill" Value="Red" />
                    <Setter Property="Opacity" Value="0.2" />
                </KeyFrame>
            </Animation>
        </Style.Animations>
    </Style>

    <!-- Blue glow style -->
    <Style Selector="Button.CircularButton.GreenGlow /template/ Ellipse#GlowEffect">
        <Setter Property="Fill" Value="{DynamicResource AccentBrush}" />
        <Setter Property="Opacity" Value="0.7" />
    </Style>
    
    <!-- Default icon - empty circle -->
    <Style Selector="Button.CircularButton Path#IconPath">
        <Setter Property="Data" Value="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10s10-4.48 10-10S17.52,2 12,2z M12,20c-4.41,0-8-3.59-8-8s3.59-8 8-8s8,3.59 8,8S16.41,20 12,20z" />
    </Style>
    
    <!-- X icon for waiting state -->
    <Style Selector="Button.CircularButton.RedPulse Path#IconPath">
        <Setter Property="Data" Value="M12,2C6.47,2 2,6.47 2,12s4.47,10 10,10s10-4.47 10-10S17.53,2 12,2z M12,20c-4.41,0-8-3.59-8-8s3.59-8 8-8s8,3.59 8,8S16.41,20 12,20z M15.59,7l-3.59,3.59l-3.59-3.59l-1.41,1.41l3.59,3.59l-3.59,3.59l1.41,1.41l3.59-3.59l3.59,3.59l1.41-1.41l-3.59-3.59l3.59-3.59z" />
    </Style>
    
    <!-- Checkmark icon for connected state -->
    <Style Selector="Button.CircularButton.GreenGlow Path#IconPath">
        <Setter Property="Data" Value="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10s10-4.48 10-10S17.52,2 12,2z M12,20c-4.41,0-8-3.59-8-8s3.59-8 8-8s8,3.59 8,8S16.41,20 12,20z M16.59,7.58L10,14.17l-2.59-2.58L6,13l4,4l8-8z" />
    </Style>
</UserControl.Styles>
    
    <ScrollViewer>
        <Grid Background="{DynamicResource HeaderBackground}" Height="80">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <!-- Logo and branding -->
            <StackPanel Orientation="Vertical" Grid.Column="0" Margin="10,0,0,0">
                <!-- Logo -->
                <Svg Width="150" Margin="0,10,0,0" Path="/Assets/Icons/openipc-logo.svg" />

                <!-- Version + icon row -->
                <StackPanel Orientation="Horizontal" Margin="0,6,0,8" Spacing="6"
                            Opacity="0.6">
                    <TextBlock FontSize="10" Foreground="White"
                               VerticalAlignment="Center"
                               Text="{Binding AppVersionText}" />

                    <Button Name="TelegramButton" Padding="4,2" Click="TelegramButton_OnClick"
                            Background="Transparent" BorderThickness="0"
                            VerticalContentAlignment="Center"
                            ToolTip.Tip="Telegram">
                        <Svg Width="14" Path="/Assets/Icons/ic-telegram.svg" />
                    </Button>
                    <Button Name="GithubButton" Padding="4,2" Click="GithubButton_OnClick"
                            Background="Transparent" BorderThickness="0"
                            VerticalContentAlignment="Center"
                            ToolTip.Tip="GitHub">
                        <Svg Width="14" Path="/Assets/Icons/mdi-github.svg" />
                    </Button>
                    <Button Name="ReportBugButton" Padding="4,2" Click="ReportBugButton_OnClick"
                            Background="Transparent" BorderThickness="0"
                            VerticalContentAlignment="Center"
                            ToolTip.Tip="Report a bug on GitHub">
                        <Path Data="M8,2 L9.88,3.88 M14.12,3.88 L16,2 M12,20 C8.7,20 6,17.3 6,14 L6,11 C6,8.79 7.79,7 10,7 L14,7 C16.21,7 18,8.79 18,11 L18,14 C18,17.3 15.3,20 12,20 Z M12,20 L12,11 M6.53,9 C4.6,8.8 3,7.1 3,5 M6,13 L2,13 M6,17 L3,17 M17.47,9 C19.4,8.8 21,7.1 21,5 M18,13 L22,13 M21,17 L18,17"
                              Stroke="White" StrokeThickness="1.5"
                              Width="14" Height="14" Stretch="Uniform" />
                    </Button>
                    <Button Padding="4,2"
                            Background="Transparent" BorderThickness="0"
                            VerticalContentAlignment="Center"
                            Command="{Binding ToggleThemeCommand}"
                            ToolTip.Tip="Toggle theme">
                        <Panel>
                            <!-- Sun icon (light mode) -->
                            <Path Data="M12,16 A4,4 0 1,0 12,8 A4,4 0 1,0 12,16 Z M12,2 L12,4 M12,20 L12,22 M4.93,4.93 L6.34,6.34 M17.66,17.66 L19.07,19.07 M2,12 L4,12 M20,12 L22,12 M6.34,17.66 L4.93,19.07 M19.07,4.93 L17.66,6.34"
                                  Stroke="White" StrokeThickness="1.5"
                                  Width="14" Height="14" Stretch="Uniform"
                                  IsVisible="{Binding !IsDarkTheme}" />
                            <!-- Moon icon (dark mode) -->
                            <Path Data="M21,12.79 A9,9 0 1,1 11.21,3 A7,7 0 0,0 21,12.79 Z"
                                  Stroke="White" StrokeThickness="1.5"
                                  Width="14" Height="14" Stretch="Uniform"
                                  IsVisible="{Binding IsDarkTheme}" />
                        </Panel>
                    </Button>
                </StackPanel>
            </StackPanel>

            <!-- Column 1 empty -->
            <Border Grid.Column="1" />

            <Grid Grid.Column="2">
                <!-- Device info right-aligned -->
                <Grid ColumnDefinitions="Auto,Auto" RowDefinitions="Auto,Auto,Auto"
                      ShowGridLines="False"
                      Margin="5"
                      HorizontalAlignment="Right"
                      VerticalAlignment="Center">
                    <!-- SOC -->
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="SOC:"
                               Margin="5,0,0,5"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="White" />
                    <TextBlock Grid.Row="0" Grid.Column="1"
                               Margin="5,0,0,5"
                               Text="{Binding Soc}"
                               Width="75"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="White" />

                    <!-- Sensor -->
                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Sensor:"
                               Margin="5,0,0,5"
                               VerticalAlignment="Center"
                               HorizontalAlignment="Right"
                               Foreground="White" />
                    <TextBlock Grid.Row="1" Grid.Column="1"
                               Text="{Binding Sensor}"
                               Margin="5,0,0,5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="White" />
                    <!-- Network Card -->
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Net Card:"
                               Margin="5,0,0,5"
                               HorizontalAlignment="Right"
                               VerticalAlignment="Center"
                               Foreground="White" />
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding NetworkCardType}"
                               Margin="5,0,0,5"
                               HorizontalAlignment="Left"
                               VerticalAlignment="Center"
                               Foreground="White" />
                </Grid>
            </Grid>

            <!-- Connection Fields -->
            <Grid Grid.Column="3" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- IP Address -->
                <!-- <TextBox Width="200" Height="30" Watermark="IP Address" -->
                <!--          Text="{Binding IpAddress, Mode=TwoWay}" -->
                <!--          Background="{DynamicResource HeaderInputBackground}" -->
                <!--          HorizontalAlignment="Left" -->
                <!--          Classes="InputBox" Grid.Row="0" Margin="0,5,0,0" -->
                <!--          ToolTip.Tip="Device IP Address" /> -->
                <!-- Replace TextBox with ComboBox for IP Address -->
                <!-- Replace TextBox with AutoCompleteBox for IP Address -->
                <AutoCompleteBox Width="200"
                                 Height="30"
                                 Watermark="IP Address"
                                 Text="{Binding IpAddress, Mode=TwoWay}"
                                 ItemsSource="{Binding CachedIpAddresses}"
                                 SelectedItem="{Binding SelectedCachedIpAddress}"
                                 Background="{DynamicResource HeaderInputBackground}"
                                 Foreground="{DynamicResource PrimaryTextForeground}"
                                 HorizontalAlignment="Left"
                                 Classes="InputBox"
                                 Grid.Row="0"
                                 Margin="0,5,0,0"
                                 FilterMode="Contains"
                                 ToolTip.Tip="Device IP Address" />

                <StackPanel Orientation="Horizontal" Spacing="10" Grid.Row="1">

                    <!-- Device Type -->
                    <ComboBox Width="120" Height="30" ToolTip.Tip="Device Type"
                              Background="{DynamicResource HeaderInputBackground}"
                              Foreground="{DynamicResource PrimaryTextForeground}"
                              Margin="0,5,0,5"
                              ItemsSource="{Binding DeviceTypes}"
                              SelectedItem="{Binding SelectedDeviceType, Mode=TwoWay}" />

                    <!-- Port -->
                    <TextBox Width="50" Height="30" Watermark="Port"
                             Background="{DynamicResource HeaderInputBackground}"
                             Foreground="{DynamicResource PrimaryTextForeground}"
                             Margin="0,5,0,5"
                             Text="{Binding Port, Mode=TwoWay}" Classes="InputBox"
                             ToolTip.Tip="Port" />

                    <!-- Password -->
                    <TextBox Width="100" Height="30" Watermark="Password"
                             Background="{DynamicResource HeaderInputBackground}"
                             Foreground="{DynamicResource PrimaryTextForeground}"
                             PasswordChar="*"
                             Margin="0,5,0,5"
                             Text="{Binding Password, Mode=TwoWay}" Classes="InputBox"
                             ToolTip.Tip="Password" />
                </StackPanel>
            </Grid>

            <!-- Circular Connect Button -->
            <StackPanel Grid.Column="4" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="5,0,10,0">
                <Button Width="50" Height="50" Command="{Binding ConnectCommand}"
                        IsEnabled="{Binding CanConnect}"
                        Classes="CircularButton"
                        Classes.RedPulse="{Binding IsWaiting}"
                        Classes.GreenGlow="{Binding IsConnected}">
                    <!-- Use a single path instead of multiple elements -->
                    <Path x:Name="IconPath" 
                          Fill="White"
                          Width="24"
                          Height="24" 
                          Data="M12,2C6.48,2 2,6.48 2,12s4.48,10 10,10s10-4.48 10-10S17.52,2 12,2z M12,20c-4.41,0-8-3.59-8-8s3.59-8 8-8s8,3.59 8,8S16.41,20 12,20z" />
                </Button>

                <TextBlock Text="Connect" Foreground="White" FontSize="12" HorizontalAlignment="Center" />
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>
